page { background: #f4f7f5; color: #19312c; font-family: sans-serif; }
.page { min-height: 100vh; padding: 28rpx 30rpx 48rpx; box-sizing: border-box; }
.brand { color: #23806d; font-size: 26rpx; font-weight: 700; }
.title { margin-top: 16rpx; font-size: 48rpx; font-weight: 700; }
.subtitle, .muted { color: #6b7874; font-size: 26rpx; line-height: 1.7; }
.panel { margin-top: 24rpx; padding: 26rpx; background: #fff; border: 1rpx solid #dce6e2; border-radius: 12rpx; }
.field { margin-bottom: 22rpx; }
.label { display: block; margin-bottom: 10rpx; font-size: 26rpx; font-weight: 600; }
.input { width: 100%; height: 76rpx; padding: 0 20rpx; box-sizing: border-box; border: 1rpx solid #cbd9d4; border-radius: 8rpx; background: #fff; font-size: 28rpx; line-height: 76rpx; }
.textarea { width: 100%; height: 240rpx; min-height: 240rpx; padding: 18rpx 20rpx; box-sizing: border-box; border: 1rpx solid #cbd9d4; border-radius: 8rpx; background: #fff; font-size: 28rpx; line-height: 1.55; }
.primary, .secondary { height: 84rpx; margin-top: 16rpx; border-radius: 8rpx; font-size: 30rpx; line-height: 84rpx; }
.primary { background: #277a68; color: #fff; }
.secondary { background: #e5efeb; color: #173a34; }
.primary::after, .secondary::after { border: 0; }
.section-title { font-size: 32rpx; font-weight: 700; }
.list-item { padding: 24rpx 0; border-bottom: 1rpx solid #e6ece9; }
.answer { margin-top: 22rpx; padding: 24rpx; background: #e9f3ef; border-left: 6rpx solid #277a68; line-height: 1.7; }
