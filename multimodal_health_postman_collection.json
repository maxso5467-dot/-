    },
    {
      "name": "问诊 Consultation",
      "item": [
        {
          "name": "创建问诊会话",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('sessionId', json.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"皮肤红疹瘙痒咨询\",\n  \"channel\": \"multimodal\",\n  \"initialMessage\": \"小腿起红疹两天，很痒，晚上更明显。\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/consultations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "consultations"
              ]
            }
          }
        },
        {
          "name": "发送文本消息",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"小腿起红疹两天，很痒，晚上更明显。\",\n  \"context\": {\n    \"duration\": \"2天\",\n    \"bodyPart\": \"小腿\",\n    \"severity\": \"中等\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/consultations/{{sessionId}}/messages/text",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "consultations",
                "{{sessionId}}",
                "messages",
                "text"
              ]
            },
            "description": "发送用户文本，并返回 AI 问诊回复。"
          }
        },
        {
          "name": "上传图片消息",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.fileId) pm.collectionVariables.set('fileId', json.data.fileId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "description",
                  "value": "小腿红疹图片",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/consultations/{{sessionId}}/messages/image",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "consultations",
                "{{sessionId}}",
                "messages",
                "image"
              ]
            }
          }
        },
        {
          "name": "上传语音消息",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "language",
                  "value": "zh-CN",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/consultations/{{sessionId}}/messages/voice",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "consultations",
                "{{sessionId}}",
                "messages",
                "voice"
              ]
            }
          }
